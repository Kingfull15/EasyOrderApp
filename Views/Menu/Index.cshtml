@model Dictionary<string, List<MenuItem>>
@{
    ViewData["Title"] = "Restaurant Menu - Table " + ViewBag.TableNumber;
}

<div class="container">
    <h1 class="text-center mb-4">Welcome to Our Restaurant</h1>
    <h3 class="text-center mb-4">Table @ViewBag.TableNumber</h3>

    <div class="row">
        <div class="col-md-8">
            @foreach (var category in Model)
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <h3>@category.Key</h3>
                    </div>
                    <div class="card-body">
                        @foreach (var item in category.Value)
                        {
                            <div class="row menu-item mb-3 p-3 border rounded">
                                <div class="col-md-8">
                                    <h5>@item.Name</h5>
                                    <p class="text-muted">@item.Description</p>
                                    <strong class="text-success">@item.Price.ToString("F2") Денари</strong>
                                </div>
                                <div class="col-md-4 text-right">
                                    <form asp-action="AddToOrder" method="post" class="d-inline">
                                        <input type="hidden" name="menuItemId" value="@item.Id" />
                                        <div class="input-group">
                                            <input type="number" name="quantity" value="1" min="1" max="10" class="form-control" style="width: 70px;" />
                                            <div class="input-group-append">
                                                <button type="submit" class="btn btn-primary">Add to Order</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card position-sticky" style="top: 20px;">
                <div class="card-header">
                    <h4>Quick Actions</h4>
                </div>
                <div class="card-body">
                    <a asp-action="ViewOrder" class="btn btn-success btn-block mb-2">View Current Order</a>
                    <a asp-action="Index" class="btn btn-secondary btn-block">Refresh Menu</a>
                </div>
            </div>
        </div>
    </div>
</div>
