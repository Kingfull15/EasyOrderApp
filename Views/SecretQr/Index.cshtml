@model SecretQrViewModel
@{
    ViewData["Title"] = "Secret QR Generator";
}

<div class="container py-5">
    <div class="card mx-auto" style="max-width: 720px;">
        <div class="card-body p-4 p-md-5 text-center">
            <h2 class="mb-2">Secret QR Generator</h2>
            <p class="text-muted mb-4">Generate a QR code that opens the menu for a selected table.</p>

            <form asp-action="Index" method="get" class="d-flex justify-content-center align-items-center mb-4" style="gap: 10px; flex-wrap: wrap;">
                <label for="tableNumber" class="fw-semibold mb-0">Table number</label>
                <input id="tableNumber" name="tableNumber" type="number" min="1" value="@Model.TableNumber" class="form-control" style="max-width: 140px;" />
                <button type="submit" class="btn btn-primary">Generate QR</button>
            </form>

            <div class="mb-4">
                <img src="data:image/png;base64,@Model.QrCodeBase64" alt="QR code for table @Model.TableNumber" class="img-fluid" style="max-width: 320px;" />
            </div>

            <div class="alert alert-light text-start border">
                <div class="fw-semibold mb-1">Table: @Model.TableNumber</div>
                <div class="small text-break">@Model.MenuUrl</div>
            </div>
        </div>
    </div>
</div>

