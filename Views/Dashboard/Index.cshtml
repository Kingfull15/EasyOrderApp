@model List<Order>
@{
    ViewData["Title"] = "Server Dashboard";
}

<div class="container-fluid">
    <h1 class="mb-4">Server Dashboard</h1>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h3>All Orders</h3>
                    <small class="text-muted">Last updated: @DateTime.Now.ToString("HH:mm:ss")</small>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>Order #</th>
                                        <th>Table</th>
                                        <th>Time</th>
                                        <th>Items</th>
                                        <th>Total</th>
                                        <th>Status</th>
                                        <th>Actions</th>
										<th>Delete</th>
                                        
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model)
                                    {
                                        <tr class="@(order.Status == "Completed" ? "table-success" : order.Status == "Preparing" ? "table-warning" : "")">
                                            <td><strong>#@order.OrderId</strong></td>
                                            <td>
                                                <a asp-action="TableView" asp-route-tableNumber="@order.TableNumber" class="btn btn-sm btn-outline-primary">
                                                    Table @order.TableNumber
                                                </a>
                                            </td>
                                            <td>@order.OrderTime.ToString("HH:mm")</td>
                                            <td>
                                                <ul class="list-unstyled mb-0">
                                                    @foreach (var item in order.Items)
                                                    {
                                                        <li><small>@item.Quantity x @item.MenuItemName</small></li>
                                                    }
                                                </ul>
                                            </td>
                                            <td><strong>@order.TotalAmount.ToString("F2") Денари</strong></td>
                                            <td>
                                                <span class="badge @(order.Status == "Pending" ? "badge-warning" : order.Status == "Preparing" ? "badge-info" : "badge-success")">
                                                    @order.Status
                                                </span>
                                            </td>
                                            <td>
                                                @if (order.Status != "Completed")
                                                {
                                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                        <input type="hidden" name="orderId" value="@order.OrderId" />
                                                        @if (order.Status == "Pending")
                                                        {
                                                            <button type="submit" name="status" value="Preparing" class="btn btn-sm btn-info">Start Preparing</button>
                                                        }
                                                        else if (order.Status == "Preparing")
                                                        {
                                                            <button type="submit" name="status" value="Completed" class="btn btn-sm btn-success">Mark Complete</button>
                                                        }
                                                    </form>
                                                }
                                            </td>
                                            <td>
                                                <form method="post" asp-action="DeleteOrder">
                                                    <input type="hidden" name="orderId" value="@order.OrderId" />
                                                    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this order?');">
                                                        Delete
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <h4>No orders yet</h4>
                            <p>Orders will appear here as customers place them.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h4>Quick Stats</h4>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3">
                            <h3 class="text-warning">@Model.Count(o => o.Status == "Pending")</h3>
                            <p>Pending Orders</p>
                        </div>
                        <div class="col-md-3">
                            <h3 class="text-info">@Model.Count(o => o.Status == "Preparing")</h3>
                            <p>Preparing</p>
                        </div>
                        <div class="col-md-3">
                            <h3 class="text-success">@Model.Count(o => o.Status == "Completed")</h3>
                            <p>Completed</p>
                        </div>
                        <div class="col-md-3">
                            <h3 class="text-primary">@Model.Sum(o => o.TotalAmount).ToString("F2") Денари </h3>
                            <p>Total Sales</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-refresh every 30 seconds
    setTimeout(function() {
        location.reload();
    }, 30000);
</script>
