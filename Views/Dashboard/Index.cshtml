@model List<Order>
@{
    ViewData["Title"] = "Server Dashboard";
}

<div class="container-fluid dashboard-page py-4">
    <div class="dashboard-hero mb-4">
        <h1 class="mb-1">Server Dashboard</h1>
        <p class="mb-1">Track live orders, update kitchen progress, and keep tables moving smoothly.</p>
        <small>Last updated: @DateTime.Now.ToString("HH:mm:ss")</small>
        <div class="mt-3">
            <a asp-controller="Dashboard" asp-action="SelectTable" class="btn continue-order-btn">Find Table Orders</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="stat-card pending">
                <div class="stat-value">@Model.Count(o => o.Status == "Pending")</div>
                <div class="stat-label">Pending Orders</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card preparing">
                <div class="stat-value">@Model.Count(o => o.Status == "Preparing")</div>
                <div class="stat-label">Preparing</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card completed">
                <div class="stat-value">@Model.Count(o => o.Status == "Completed")</div>
                <div class="stat-label">Completed</div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card sales">
                <div class="stat-value">@Model.Sum(o => o.TotalAmount).ToString("F2")</div>
                <div class="stat-label">Total Sales (Денари)</div>
            </div>
        </div>
    </div>

    <div class="card dashboard-orders-card">
        <div class="card-header dashboard-orders-header d-flex justify-content-between align-items-center">
            <h3 class="mb-0">All Orders</h3>
            <span class="orders-count-pill">@Model.Count total</span>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover dashboard-table align-middle">
                        <thead>
                            <tr>
                                <th>Order #</th>
                                <th>Table</th>
                                <th>Time</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Actions</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><strong class="order-id">#@order.OrderId</strong></td>
                                    <td>
                                        <a asp-controller="Dashboard" asp-action="TableView" asp-route-tableNumber="@order.TableNumber" class="btn btn-sm table-link-btn">
                                            Table @order.TableNumber
                                        </a>
                                    </td>
                                    <td>@order.OrderTime.ToString("HH:mm")</td>
                                    <td>
                                        <ul class="list-unstyled mb-0 order-items-list">
                                            @foreach (var item in order.Items)
                                            {
                                                <li><small>@item.Quantity x @item.MenuItemName</small></li>
                                            }
                                        </ul>
                                    </td>
                                    <td><strong class="order-total">@order.TotalAmount.ToString("F2") Денари</strong></td>
                                    <td>
                                        <span class="status-pill @(order.Status == "Pending" ? "status-pending" : order.Status == "Preparing" ? "status-preparing" : "status-completed")">
                                            @order.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (order.Status != "Completed")
                                        {
                                            <form asp-controller="Dashboard" asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="orderId" value="@order.OrderId" />
                                                @if (order.Status == "Pending")
                                                {
                                                    <button type="submit" name="status" value="Preparing" class="btn btn-sm status-action-btn">Start Preparing</button>
                                                }
                                                else if (order.Status == "Preparing")
                                                {
                                                    <button type="submit" name="status" value="Completed" class="btn btn-sm status-action-btn">Mark Complete</button>
                                                }
                                            </form>
                                        }
                                    </td>
                                    <td>
                                        <form method="post" asp-controller="Dashboard" asp-action="DeleteOrder">
                                            <input type="hidden" name="orderId" value="@order.OrderId" />
                                            <button type="submit" class="btn btn-sm delete-order-btn" onclick="return confirm('Are you sure you want to delete this order?');">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert dashboard-empty-alert text-center">
                    <h4>No orders yet</h4>
                    <p class="mb-0">Orders will appear here as customers place them.</p>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Auto-refresh every 30 seconds
    setTimeout(function() {
        location.reload();
    }, 30000);
</script>
